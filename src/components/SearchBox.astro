---
---

<div class="relative">
  <input
    id="search-input"
    type="text"
    placeholder="搜索工具..."
    class="w-full h-10 pl-4 pr-10 bg-gray-100 border-0 rounded-lg text-sm text-gray-800 placeholder-gray-400 focus:bg-white focus:ring-2 focus:ring-pink-500 transition-all"
    autocomplete="off"
    enterkeyhint="search"
  />
  <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
  </svg>
</div>

<script is:inline>
  (function() {
    var input = document.getElementById('search-input');

    function doSearch(keyword) {
      if (!keyword.trim()) {
        // 显示所有工具
        var allCards = document.querySelectorAll('[data-tool-card]');
        allCards.forEach(function(card) {
          card.style.display = 'block';
        });
        var allSections = document.querySelectorAll('[data-category-section]');
        allSections.forEach(function(sec) {
          sec.style.display = 'block';
        });
        return;
      }
      
      var k = keyword.trim().toLowerCase();
      var allCards = document.querySelectorAll('[data-tool-card]');
      var visibleSections = new Set();
      
      allCards.forEach(function(card) {
        var name = (card.dataset.name || '').toLowerCase();
        var desc = (card.dataset.desc || '').toLowerCase();
        var keywords = (card.dataset.keywords || '').toLowerCase();
        var match = name.indexOf(k) !== -1 || desc.indexOf(k) !== -1 || keywords.indexOf(k) !== -1;
        card.style.display = match ? 'block' : 'none';
        if (match) {
          visibleSections.add(card.dataset.category);
        }
      });
      
      var allSections = document.querySelectorAll('[data-category-section]');
      allSections.forEach(function(sec) {
        sec.style.display = visibleSections.has(sec.dataset.category) ? 'block' : 'none';
      });
    }

    input.addEventListener('input', function() {
      doSearch(input.value);
    });
    
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        doSearch(input.value);
      }
    });
  })();
</script>
