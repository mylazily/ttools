---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description || "200个免费在线工具，无需安装，即开即用。包含文本处理、编码加密、格式转换、计算器、趣味工具等"}>
    <meta name="keywords" content="在线工具,工具箱,Base64,MD5,JSON格式化,时间戳,UUID,密码生成,二维码">
    <meta name="author" content="在线工具箱">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://ziyuanzu.com">
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Adsense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4828591893992093" crossorigin="anonymous"></script>
    
    <style is:global>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            background: linear-gradient(135deg, #fdf2f8 0%, #fff1f2 25%, #fef3c7 50%, #ecfdf5 75%, #eff6ff 100%);
            background-attachment: fixed;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; 
            padding-bottom: 80px; 
            min-height: 100vh;
        }
        .card { 
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 1rem; 
            padding: 1.5rem; 
            border: 1px solid rgba(255, 255, 255, 0.8); 
            box-shadow: 0 4px 20px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.05); 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        }
        .card:hover { 
            box-shadow: 0 10px 40px rgba(219, 39, 119, 0.15), 0 4px 12px rgba(0,0,0,0.08); 
            border-color: rgba(244, 114, 182, 0.4); 
            transform: translateY(-4px); 
        }
        .tool-card { 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            justify-content: center; 
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 1rem; 
            padding: 1.5rem 1rem; 
            border: 1px solid rgba(255, 255, 255, 0.8); 
            box-shadow: 0 4px 15px rgba(0,0,0,0.06); 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            text-align: center; 
            text-decoration: none; 
        }
        .tool-card:hover { 
            box-shadow: 0 12px 40px rgba(219, 39, 119, 0.18), 0 6px 16px rgba(0,0,0,0.1); 
            border-color: rgba(244, 114, 182, 0.5); 
            transform: translateY(-6px) scale(1.02); 
            text-decoration: none; 
        }
        .btn-primary { 
            background: linear-gradient(135deg, #db2777 0%, #ec4899 50%, #f472b6 100%);
            color: white; 
            padding: 0.875rem 1.75rem; 
            border-radius: 0.75rem; 
            border: none; 
            cursor: pointer; 
            font-weight: 600; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(219, 39, 119, 0.3);
        }
        .btn-primary:hover { 
            transform: translateY(-2px) scale(1.02); 
            box-shadow: 0 8px 25px rgba(219, 39, 119, 0.4);
        }
        .btn-primary:active {
            transform: translateY(0);
        }
        .btn-secondary { 
            border: 2px solid #db2777; 
            color: #db2777; 
            padding: 0.875rem 1.75rem; 
            border-radius: 0.75rem; 
            background: rgba(255, 255, 255, 0.9); 
            cursor: pointer; 
            font-weight: 600; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-secondary:hover { 
            background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(219, 39, 119, 0.15);
        }
        textarea, input { 
            width: 100%; 
            padding: 1.25rem; 
            border: 2px solid #e5e7eb; 
            border-radius: 0.75rem; 
            font-family: ui-monospace, SFMono-Regular, monospace; 
            font-size: 0.875rem; 
            outline: none; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(255, 255, 255, 0.95);
        }
        textarea:focus, input:focus { 
            border-color: #db2777; 
            box-shadow: 0 0 0 4px rgba(219, 39, 119, 0.1);
            transform: translateY(-1px);
        }
        .result-box { 
            background: linear-gradient(135deg, #fdf2f8 0%, #fff7ed 100%);
            padding: 1.25rem; 
            border-radius: 0.75rem; 
            font-family: ui-monospace, SFMono-Regular, monospace; 
            font-size: 0.875rem; 
            white-space: pre-wrap; 
            word-break: break-all; 
            min-height: 80px; 
            border: 2px solid #fce7f3;
            box-shadow: inset 0 2px 8px rgba(219, 39, 119, 0.05);
        }
        .top-banner { 
            background: linear-gradient(135deg, #db2777 0%, #ec4899 30%, #f472b6 60%, #fb7185 100%);
            color: white; 
            padding: 0.75rem; 
            text-align: center; 
            font-size: 0.875rem;
            font-weight: 500;
            box-shadow: 0 4px 20px rgba(219, 39, 119, 0.3);
        }
        .top-banner a { 
            color: white; 
            text-decoration: underline; 
            font-weight: 600; 
        }
        .nav-bar { 
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.8); 
            padding: 1.25rem 0; 
            position: sticky; 
            top: 0; 
            z-index: 50;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        .bottom-nav { 
            position: fixed; 
            bottom: 0; 
            left: 0; 
            right: 0; 
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(229, 231, 235, 0.8); 
            padding: 1rem 0; 
            z-index: 50;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
        }
        .bottom-nav a { 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            text-decoration: none; 
            color: #6b7280; 
            font-size: 0.75rem; 
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .bottom-nav a:hover, .bottom-nav a.active { 
            color: #db2777; 
            transform: translateY(-2px);
        }
        .search-box {
            background: rgba(255, 255, 255, 0.95);
            border: 2px solid #e5e7eb;
            border-radius: 1rem;
            padding: 1rem 1.5rem;
            font-size: 1rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .search-box:focus {
            border-color: #db2777;
            box-shadow: 0 0 0 4px rgba(219, 39, 119, 0.1), 0 8px 30px rgba(0,0,0,0.08);
            transform: translateY(-2px);
        }
        .stat-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.85) 100%);
            backdrop-filter: blur(10px);
            border-radius: 1rem;
            padding: 1.25rem;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.8);
            box-shadow: 0 4px 15px rgba(0,0,0,0.06);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(219, 39, 119, 0.12);
        }
        .hot-badge {
            background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
        }
    </style>
</head>
<body>
    <!-- 顶部引流横幅 -->
    <div class="top-banner">
        🎁 海量精品资源，尽在 <a href="https://www.ziyuanzu.com" target="_blank">资源主站 www.ziyuanzu.com</a> →
    </div>
    
    <!-- 导航栏 -->
    <div class="nav-bar">
        <div class="max-w-6xl mx-auto px-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold bg-gradient-to-r from-pink-600 to-rose-500 bg-clip-text text-transparent flex items-center gap-3">
                🛠️ 在线工具箱
            </a>
            <a href="https://www.ziyuanzu.com" target="_blank" class="bg-gradient-to-r from-pink-600 to-rose-500 text-white px-4 py-2 rounded-full text-sm font-semibold hover:shadow-lg transition-all">
                → 访问资源主站
            </a>
        </div>
    </div>
    
    <!-- 主内容 -->
    <main class="max-w-6xl mx-auto px-4 py-8">
        <slot />
    </main>
    
    <!-- 底部导航栏 -->
    <div class="bottom-nav">
        <div class="max-w-md mx-auto grid grid-cols-5 gap-1 px-4">
            <a href="/" class="active">
                <span class="text-xl mb-1">🏠</span>
                <span>首页</span>
            </a>
            <a href="/#文本">
                <span class="text-xl mb-1">📝</span>
                <span>文本</span>
            </a>
            <a href="/#编码">
                <span class="text-xl mb-1">🔐</span>
                <span>编码</span>
            </a>
            <a href="/#计算">
                <span class="text-xl mb-1">🧮</span>
                <span>计算</span>
            </a>
            <a href="https://www.ziyuanzu.com" target="_blank">
                <span class="text-xl mb-1">📦</span>
                <span>资源</span>
            </a>
        </div>
    </div>
    
    <!-- 页脚 -->
    <footer class="text-center py-8 text-gray-500 text-sm">
        <p class="text-lg font-semibold bg-gradient-to-r from-pink-600 to-rose-500 bg-clip-text text-transparent mb-2">🛠️ 在线工具箱 - 200个免费在线工具</p>
        <p>
            <a href="https://www.ziyuanzu.com" class="text-pink-600 hover:underline font-medium">资源主站</a>
            ·
            <a href="/" class="text-pink-600 hover:underline font-medium">在线工具箱</a>
        </p>
    </footer>
</body>
</html>
