---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style>
        body { margin: 0; padding: 0 0 70px 0; background: #f5f5f5; font-family: system-ui, sans-serif; }
        .header { background: linear-gradient(90deg, #ec4899, #f43f5e); color: white; padding: 10px; text-align: center; font-size: 14px; }
        .header a { color: white; text-decoration: underline; }
        .nav { background: white; padding: 15px; border-bottom: 1px solid #eee; }
        .nav-inner { max-width: 1000px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
        .main { max-width: 1000px; margin: 0 auto; padding: 20px 15px; }
        .bottom { position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid #eee; padding: 10px 0; }
        .bottom-inner { max-width: 500px; margin: 0 auto; display: flex; justify-content: space-around; }
        .bottom a { display: flex; flex-direction: column; align-items: center; text-decoration: none; color: #666; font-size: 11px; }
    </style>
</head>
<body>
    <div class="header">🎁 资源主站：<a href="https://www.ziyuanzu.com">www.ziyuanzu.com</a></div>
    <div class="nav">
        <div class="nav-inner">
            <a href="/" style="font-size:18px;font-weight:bold;color:#333;text-decoration:none;">🛠️ 在线工具箱</a>
            <a href="https://www.ziyuanzu.com" style="color:#ec4899;text-decoration:none;font-size:14px;">→ 资源主站</a>
        </div>
    </div>
    <div class="main">
        <slot />
    </div>
    <div class="bottom">
        <div class="bottom-inner">
            <a href="/"><span style="font-size:18px;">🏠</span>首页</a>
            <a href="/"><span style="font-size:18px;">📝</span>文本</a>
            <a href="/"><span style="font-size:18px;">🔐</span>编码</a>
            <a href="/"><span style="font-size:18px;">🧮</span>计算</a>
            <a href="https://www.ziyuanzu.com"><span style="font-size:18px;">📦</span>资源</a>
        </div>
    </div>
</body>
</html>
