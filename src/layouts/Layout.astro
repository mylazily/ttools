---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; padding-bottom: 70px; }
        a { text-decoration: none; color: inherit; }
        
        /* 顶部 */
        .header { background: linear-gradient(90deg, #ec4899, #f43f5e); color: white; padding: 12px 16px; text-align: center; font-size: 14px; }
        .nav { background: white; padding: 16px; border-bottom: 1px solid #eee; }
        .nav-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 20px; font-weight: 700; color: #111; }
        .nav-link { color: #ec4899; font-size: 14px; font-weight: 600; }
        
        /* 主内容 */
        .container { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }
        
        /* 搜索 */
        .search { width: 100%; padding: 14px 18px; border: 1px solid #e5e7eb; border-radius: 12px; font-size: 16px; outline: none; margin-bottom: 24px; }
        .search:focus { border-color: #ec4899; }
        
        /* 统计 */
        .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
        @media (min-width: 768px) { .stats { grid-template-columns: repeat(7, 1fr); } }
        .stat { background: white; padding: 16px; border-radius: 12px; text-align: center; border: 1px solid #eee; }
        .stat-num { font-size: 20px; font-weight: 700; color: #ec4899; }
        .stat-label { font-size: 12px; color: #666; margin-top: 4px; }
        
        /* 工具网格 - hvideos标准布局 */
        .tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
        @media (min-width: 640px) { .tools-grid { grid-template-columns: repeat(4, 1fr); } }
        @media (min-width: 768px) { .tools-grid { grid-template-columns: repeat(5, 1fr); } }
        @media (min-width: 1024px) { .tools-grid { grid-template-columns: repeat(6, 1fr); } }
        
        /* hvideos标准卡片 - 纯白，简单hover */
        .tool-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px 12px; text-align: center; transition: all .2s; display: block; }
        .tool-card:hover { border-color: #ec4899; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(236,72,153,.15); }
        .tool-icon { font-size: 28px; margin-bottom: 8px; }
        .tool-name { font-size: 13px; color: #333; font-weight: 500; }
        
        /* 分类标题 */
        .section-title { font-size: 18px; font-weight: 700; color: #111; margin: 32px 0 16px; padding-bottom: 8px; border-bottom: 2px solid #fce7f3; }
        
        /* 底部导航 */
        .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid #eee; padding: 10px 0; z-index: 100; }
        .bottom-inner { max-width: 500px; margin: 0 auto; display: flex; justify-content: space-around; }
        .nav-item { display: flex; flex-direction: column; align-items: center; font-size: 11px; color: #666; }
        .nav-item.active { color: #ec4899; }
        .nav-icon { font-size: 20px; margin-bottom: 2px; }
    </style>
</head>
<body>
    <div class="header">
        🎁 海量精品资源，尽在 <a href="https://www.ziyuanzu.com" style="color:white;text-decoration:underline;font-weight:600;">资源主站</a>
    </div>
    <div class="nav">
        <div class="nav-inner">
            <a href="/" class="logo">🛠️ 在线工具箱</a>
            <a href="https://www.ziyuanzu.com" class="nav-link">→ 资源主站</a>
        </div>
    </div>
    <div class="container">
        <slot />
    </div>
    <div class="bottom-nav">
        <div class="bottom-inner">
            <a href="/" class="nav-item active"><span class="nav-icon">🏠</span>首页</a>
            <a href="/#文本" class="nav-item"><span class="nav-icon">📝</span>文本</a>
            <a href="/#编码" class="nav-item"><span class="nav-icon">🔐</span>编码</a>
            <a href="/#计算" class="nav-item"><span class="nav-icon">🧮</span>计算</a>
            <a href="https://www.ziyuanzu.com" class="nav-item"><span class="nav-icon">📦</span>资源</a>
        </div>
    </div>
</body>
</html>
