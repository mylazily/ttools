---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 - 页面不存在" description="页面不存在">
  <div class="text-center py-20">
    <div class="text-6xl mb-4">😅</div>
    <h1 class="text-3xl font-bold text-gray-800 mb-3">404</h1>
    <p class="text-gray-500 mb-6">页面不存在或已移除</p>
    <a 
      href="/" 
      class="inline-flex items-center gap-1 px-5 py-2.5 bg-pink-500 hover:bg-pink-600 text-white font-medium rounded-lg text-sm transition-colors"
    >
      <span>←</span>
      <span>返回首页</span>
    </a>
  </div>
</Layout>
