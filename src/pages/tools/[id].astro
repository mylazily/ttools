---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const tools = [
    { id: 'word-count', name: '字数统计', icon: '📏' },
    { id: 'text-dedup', name: '文本去重', icon: '📋' },
    { id: 'case-convert', name: '大小写转换', icon: '🔤' },
    { id: 'text-reverse', name: '文本反转', icon: '🔄' },
    { id: 'html-escape', name: 'HTML转义', icon: '📝' },
    { id: 'lorem', name: 'Lorem生成', icon: '📄' },
    { id: 'base64', name: 'Base64编码', icon: '🔐' },
    { id: 'url-encode', name: 'URL编码', icon: '🔗' },
    { id: 'uuid', name: 'UUID生成', icon: '🆔' },
    { id: 'password', name: '密码生成器', icon: '🔐' },
    { id: 'json-format', name: 'JSON格式化', icon: '📝' },
    { id: 'random', name: '随机数生成', icon: '🔢' },
    { id: 'bmi', name: 'BMI计算器', icon: '⚖️' },
    { id: 'loan', name: '贷款计算器', icon: '💰' },
    { id: 'trim', name: '空格清理', icon: '🧹' },
    { id: 'sort', name: '文本排序', icon: '📊' },
    { id: 'shuffle', name: '随机打乱', icon: '🎲' },
    { id: 'unique', name: '数组去重', icon: '✨' },
    { id: 'dice', name: '掷骰子', icon: '🎲' },
    { id: 'coin', name: '抛硬币', icon: '🪙' },
    { id: 'lotto', name: '彩票号码', icon: '🎫' },
    { id: 'pick', name: '随机抽选', icon: '🎯' },
    { id: 'timestamp', name: '时间戳转换', icon: '⏰' },
    { id: 'rmb', name: '人民币大写', icon: '💴' },
    { id: 'emailcheck', name: '邮箱验证', icon: '📧' },
    { id: 'phonecheck', name: '手机号验证', icon: '📱' },
  ];
  return tools.map(tool => ({ params: { id: tool.id }, props: tool }));
}

const { id, name, icon } = Astro.props;
---

<Layout title={`${name} - 在线工具箱`} description="">
    <!-- 这里Astro属性渲染：不要加引号！直接写 data-tool-id={id} -->
    <div id="tool-meta" data-tool-id={id} style="display:none;"></div>
    
    <div class="mb-6">
        <a href="/" class="text-pink-600 hover:underline text-sm">← 返回首页</a>
    </div>

    <div class="text-center mb-8">
        <div class="text-5xl mb-4">{icon}</div>
        <h1 class="text-3xl font-bold text-gray-800 mb-2">{name}</h1>
    </div>

    <div class="card">
        <div class="mb-4">
            <textarea id="input" rows="8" placeholder="在此输入内容..." class="w-full"></textarea>
        </div>
        
        <div id="extra-inputs"></div>
        
        <div class="flex flex-wrap gap-3 mb-4">
            <button onclick="process()" class="btn-primary">处理</button>
            <button onclick="copyResult()" class="btn-secondary">复制</button>
            <button onclick="clearAll()" class="btn-secondary">清空</button>
        </div>
        
        <div class="mb-4">
            <label class="block text-gray-700 font-medium mb-2">结果：</label>
            <div id="result" class="result-box"></div>
        </div>
    </div>

    <script is:inline>
        const TOOL_ID = document.getElementById('tool-meta').dataset.toolId;
        
        function numToChinese(num) {
            const digits = ['零','壹','贰','叁','肆','伍','陆','柒','捌','玖'];
            const units = ['','拾','佰','仟','万'];
            let n = Math.round(parseFloat(num) * 100);
            let intPart = Math.floor(n / 100);
            let decPart = n % 100;
            let result = '';
            let str = intPart.toString();
            for(let i = 0; i < str.length; i++) {
                let d = parseInt(str[i]);
                let u = str.length - i - 1;
                result += digits[d] + (d ? units[u] : '');
            }
            result = result.replace(/零+/g, '零').replace(/零$/, '') + '元';
            if(decPart > 0) {
                if(Math.floor(decPart/10) > 0) result += digits[Math.floor(decPart/10)] + '角';
                if(decPart % 10 > 0) result += digits[decPart % 10] + '分';
            } else { result += '整'; }
            return result;
        }
        
        if(TOOL_ID === 'bmi') {
            document.getElementById('extra-inputs').innerHTML = `
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div><label class="text-gray-700 text-sm">身高(cm)</label><input type="number" id="h" value="170" class="w-full"></div>
                    <div><label class="text-gray-700 text-sm">体重(kg)</label><input type="number" id="w" value="65" class="w-full"></div>
                </div>`;
        }
        if(TOOL_ID === 'loan') {
            document.getElementById('extra-inputs').innerHTML = `
                <div class="grid grid-cols-3 gap-4 mb-4">
                    <div><label class="text-gray-700 text-sm">贷款(万)</label><input type="number" id="a" value="100" class="w-full"></div>
                    <div><label class="text-gray-700 text-sm">年利率%</label><input type="number" id="r" value="4.2" class="w-full"></div>
                    <div><label class="text-gray-700 text-sm">年限</label><input type="number" id="y" value="30" class="w-full"></div>
                </div>`;
        }
        
        function process() {
            const input = document.getElementById('input').value.trim();
            let result = '';
            
            if(TOOL_ID === 'word-count') {
                result = `字符数: ${input.length}\n中文字符: ${(input.match(/[\u4e00-\u9fa5]/g) || []).length}\n行数: ${input ? input.split('\n').length : 0}`;
            }
            else if(TOOL_ID === 'text-dedup') {
                result = [...new Set(input.split('\n').filter(l => l.trim()))].join('\n');
            }
            else if(TOOL_ID === 'case-convert') {
                result = `【大写】\n${input.toUpperCase()}\n\n【小写】\n${input.toLowerCase()}`;
            }
            else if(TOOL_ID === 'text-reverse') {
                result = input.split('').reverse().join('');
            }
            else if(TOOL_ID === 'html-escape') {
                result = input.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            }
            else if(TOOL_ID === 'lorem') {
                result = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor. '.repeat(8);
            }
            else if(TOOL_ID === 'base64') {
                result = btoa(unescape(encodeURIComponent(input || '测试文本')));
            }
            else if(TOOL_ID === 'url-encode') {
                result = encodeURIComponent(input || '测试文本');
            }
            else if(TOOL_ID === 'uuid') {
                result = Array(20).fill(0).map(() => crypto.randomUUID()).join('\n');
            }
            else if(TOOL_ID === 'password') {
                const pc = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%';
                result = Array(10).fill(0).map(() => Array(16).fill(0).map(() => pc[Math.floor(Math.random()*pc.length)]).join('')).join('\n\n');
            }
            else if(TOOL_ID === 'json-format') {
                try { result = JSON.stringify(JSON.parse(input || '{"name":"test","value":123}'), null, 2); }
                catch(e) { result = '❌ JSON格式错误'; }
            }
            else if(TOOL_ID === 'random') {
                result = Array(20).fill(0).map(() => Math.floor(Math.random()*100)+1).join(', ');
            }
            else if(TOOL_ID === 'bmi') {
                const h = parseFloat(document.getElementById('h').value) / 100;
                const w = parseFloat(document.getElementById('w').value);
                const bmi = (w / (h * h)).toFixed(1);
                const level = bmi < 18.5 ? '偏瘦' : bmi < 24 ? '正常 ✓' : bmi < 28 ? '偏胖' : '肥胖';
                result = `BMI: ${bmi}\n判定: ${level}`;
            }
            else if(TOOL_ID === 'loan') {
                const a = parseFloat(document.getElementById('a').value) * 10000;
                const r = parseFloat(document.getElementById('r').value) / 100 / 12;
                const m = parseFloat(document.getElementById('y').value) * 12;
                const pay = a * r * Math.pow(1+r, m) / (Math.pow(1+r, m) - 1);
                result = `月供: ${pay.toFixed(2)} 元\n总还款: ${(pay*m).toFixed(2)} 元`;
            }
            else if(TOOL_ID === 'trim') {
                result = input.replace(/\s+/g, ' ').trim();
            }
            else if(TOOL_ID === 'sort') {
                result = input.split('\n').sort((a,b) => a.localeCompare(b, 'zh-CN')).join('\n');
            }
            else if(TOOL_ID === 'shuffle') {
                result = input.split('\n').sort(() => Math.random() - 0.5).join('\n');
            }
            else if(TOOL_ID === 'unique') {
                result = [...new Set(input.split('\n'))].join('\n');
            }
            else if(TOOL_ID === 'dice') {
                result = '🎲 ' + (Math.floor(Math.random()*6)+1);
            }
            else if(TOOL_ID === 'coin') {
                result = Math.random()>0.5 ? '🪙 正面' : '🪙 反面';
            }
            else if(TOOL_ID === 'lotto') {
                const red = []; while(red.length<6) { let n=Math.floor(Math.random()*33)+1; if(!red.includes(n)) red.push(n); }
                red.sort((a,b)=>a-b); result = `红球: ${red.join(' ')}   蓝球: ${Math.floor(Math.random()*16)+1}`;
            }
            else if(TOOL_ID === 'pick') {
                const items = input.split('\n').filter(i=>i.trim());
                result = items.length ? '🎯 ' + items[Math.floor(Math.random()*items.length)] : '请每行输入一个选项';
            }
            else if(TOOL_ID === 'timestamp') {
                const now = Date.now();
                result = `当前毫秒: ${now}\n当前秒: ${Math.floor(now/1000)}\n时间: ${new Date().toLocaleString('zh-CN')}`;
            }
            else if(TOOL_ID === 'rmb') {
                result = numToChinese(input || '12345.67');
            }
            else if(TOOL_ID === 'emailcheck') {
                result = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input) ? '✅ 邮箱格式正确' : '❌ 邮箱格式错误';
            }
            else if(TOOL_ID === 'phonecheck') {
                result = /^1[3-9]\d{9}$/.test(input.replace(/\D/g,'')) ? '✅ 手机号格式正确' : '❌ 手机号格式错误';
            }
            
            document.getElementById('result').textContent = result;
        }
        
        function copyResult() {
            navigator.clipboard.writeText(document.getElementById('result').textContent);
            alert('✅ 已复制');
        }
        
        function clearAll() {
            document.getElementById('input').value = '';
            document.getElementById('result').textContent = '';
        }
        
        process();
    </script>
</Layout>
