---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

const tools: Record<string, any> = {
    'word-count': { name: '字数统计', icon: '📏', cat: '文本' },
    'text-dedup': { name: '文本去重', icon: '📋', cat: '文本' },
    'case-convert': { name: '大小写转换', icon: '🔤', cat: '文本' },
    'base64': { name: 'Base64编码', icon: '🔐', cat: '编码' },
    'md5': { name: 'MD5加密', icon: '🔍', cat: '编码' },
    'json-format': { name: 'JSON格式化', icon: '📝', cat: '转换' },
    'timestamp': { name: '时间戳转换', icon: '⏰', cat: '转换' },
    'bmi': { name: 'BMI计算器', icon: '⚖️', cat: '计算' },
    'password': { name: '密码生成器', icon: '🔐', cat: '编码' },
    'uuid': { name: 'UUID生成', icon: '🆔', cat: '编码' },
};

const tool = tools[id] || { name: '工具', icon: '🛠️', cat: '其他' };
---

<Layout title={`${tool.name} - 在线工具箱`} description={tool.name}>
    <div class="card">
        <div class="card-title">
            <div class="card-icon">{tool.icon}</div>
            <h1 class="card-h1">{tool.name}</h1>
        </div>
        
        <textarea id="input" rows="8" placeholder="在此输入内容..."></textarea>
        
        <div class="btn-row">
            <button class="btn-primary" onclick="process()">转换</button>
            <button class="btn-secondary" onclick="copy()">复制</button>
        </div>
        
        <div id="result" class="result-box">结果将显示在这里</div>
    </div>
    
    <script is:inline>
        function process() {
            const v = document.getElementById('input').value;
            document.getElementById('result').textContent = v || '请输入内容';
        }
        function copy() {
            navigator.clipboard.writeText(document.getElementById('result').textContent);
        }
    </script>
</Layout>
