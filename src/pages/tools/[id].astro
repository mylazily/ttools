            else if(TOOL_ID==='blake2')result='BLAKE2: '+input;
            else if(TOOL_ID==='argon2')result='Argon2: '+input;
            else if(TOOL_ID==='bcrypt')result='Bcrypt: '+input;
            
            // 转换格式化
            else if(TOOL_ID==='json-format'){try{result=JSON.stringify(JSON.parse(input||'{"test":123}'),null,2)}catch(e){result='JSON错误'}}
            else if(TOOL_ID==='json-minify'){try{result=JSON.stringify(JSON.parse(input||'{"a":1}'))}catch(e){result='JSON错误'}}
            else if(TOOL_ID==='xml-format')result='XML格式化: '+input;
            else if(TOOL_ID==='sql-format')result='SQL格式化: '+input;
            else if(TOOL_ID==='base-convert'){const n=parseInt(document.getElementById('bn')?.value)||255;result=`十进制:${n}\n二进制:${n.toString(2)}\n八进制:${n.toString(8)}\n十六进制:${n.toString(16).toUpperCase()}`}
            else if(TOOL_ID==='timestamp'){const n=Date.now(),t=parseInt(input)||n;result=`毫秒:${n}\n\n${new Date(t).toLocaleString('zh-CN')}`}
            else if(TOOL_ID==='timestamp-now'){const n=Date.now();result=`毫秒:${n}\n秒:${Math.floor(n/1000)}\n${new Date().toLocaleString('zh-CN')}`}
            else if(TOOL_ID==='timefmt'){const d=new Date();result=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`}
            else if(TOOL_ID==='urldiff'){try{const u=new URL(input||'https://a.com?a=1');result=`协议:${u.protocol}\n域名:${u.hostname}\n路径:${u.pathname}\n\n参数:\n${Array.from(u.searchParams).map(([k,v])=>`${k}=${v}`).join('\n')}`}catch(e){result='输入URL'}}
            else if(TOOL_ID==='query-parse'){try{const u=new URL('?'+input,'http://x');result=JSON.stringify(Object.fromEntries(u.searchParams),null,2)}catch(e){result='a=1&b=2'}}
            else if(TOOL_ID==='query-build'){try{const o=JSON.parse(input||'{"a":"1"}');result=new URLSearchParams(o).toString()}catch(e){result='{"a":"1"}'}}
            else if(TOOL_ID==='pixel'){const p=parseInt(input)||16;result=`${p}px = ${(p/16).toFixed(4)}rem = ${(p*0.264583).toFixed(2)}mm`}
            else if(TOOL_ID==='rem-px'){const b=parseInt(document.getElementById('base')?.value)||16,v=parseInt(input)||1;result=`${v}rem = ${v*b}px`}
            else if(TOOL_ID==='em-px'){const b=parseInt(document.getElementById('base')?.value)||16,v=parseInt(input)||1;result=`${v}em = ${v*b}px`}
            else if(TOOL_ID==='pt-px'){const p=parseInt(input)||12;result=`${p}pt = ${(p*96/72).toFixed(2)}px`}
            else if(TOOL_ID==='cm-px'){const c=parseFloat(input)||1;result=`${c}cm = ${(c*96/2.54).toFixed(2)}px`}
            else if(TOOL_ID==='inch-px'){const i=parseFloat(input)||1;result=`${i}英寸 = ${i*96}px = ${i*72}pt`}
            else if(TOOL_ID==='hexrgb'){const h=(document.getElementById('hex')?.value||'db2777').replace('#','');const r=parseInt(h.substr(0,2),16),g=parseInt(h.substr(2,2),16),b=parseInt(h.substr(4,2),16);result=`#${h} = rgb(${r},${g},${b})`}
            else if(TOOL_ID==='rgb-hex'){const r=parseInt(document.getElementById('r')?.value)||219,g=parseInt(document.getElementById('g')?.value)||39,b=parseInt(document.getElementById('b')?.value)||119;result=`rgb(${r},${g},${b}) = #${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`.toUpperCase()}
            else if(TOOL_ID==='rgb-hsl'){const r=parseInt(document.getElementById('r')?.value)||219,g=parseInt(document.getElementById('g')?.value)||39,b=parseInt(document.getElementById('b')?.value)||119;const [h,s,l]=rgbToHsl(r,g,b);result=`rgb(${r},${g},${b}) = hsl(${h}, ${s}%, ${l}%)`}
            else if(TOOL_ID==='hsl-rgb')result='HSL: '+input;
            else if(TOOL_ID==='rgb-hsv'){const r=parseInt(document.getElementById('r')?.value)||219,g=parseInt(document.getElementById('g')?.value)||39,b=parseInt(document.getElementById('b')?.value)||119;const [h,s,v]=rgbToHsv(r,g,b);result=`rgb(${r},${g},${b}) = hsv(${h}, ${s}%, ${v}%)`}
            else if(TOOL_ID==='hsv-rgb')result='HSV: '+input;
            else if(TOOL_ID==='cmyk-rgb'){const c=parseInt(document.getElementById('r')?.value)||0,m=parseInt(document.getElementById('g')?.value)||0,y=parseInt(document.getElementById('b')?.value)||0,k=parseInt(document.getElementById('hh')?.value)||0;const r=255*(1-c/100)*(1-k/100),g=255*(1-m/100)*(1-k/100),b=255*(1-y/100)*(1-k/100);result=`CMYK(${c},${m},${y},${k}) = RGB(${Math.round(r)},${Math.round(g)},${Math.round(b)})`}
            else if(TOOL_ID==='csv-json'){try{const l=(input||'n,a\n张,25').trim().split('\n'),h=l[0].split(',');result=JSON.stringify(l.slice(1).map(ln=>Object.fromEntries(h.map((hh,i)=>[hh,ln.split(',')[i]?.trim()]))),null,2)}catch(e){result='name,age\n张三,25'}}
            else if(TOOL_ID==='jsoncsv'){try{const a=JSON.parse(input||'[{"n":"张"}]');const h=Object.keys(a[0]);result=h.join(',')+'\n'+a.map(o=>h.map(x=>o[x]).join(',')).join('\n')}catch(e){result='输入JSON数组'}}
            else if(TOOL_ID==='yaml-json'){const l=(input||'n:张\na:25').trim().split('\n'),o={};l.forEach(ln=>{const [k,v]=ln.split(':');if(k&&v)o[k.trim()]=v.trim()});result=JSON.stringify(o,null,2)}
            else if(TOOL_ID==='mime-type')result='.html→text/html\n.css→text/css\n.js→application/javascript\n.json→application/json\n.png→image/png\n.jpg→image/jpeg';
            else if(TOOL_ID==='unit-convert'){const c=parseFloat(document.getElementById('c')?.value)||25,m=parseFloat(document.getElementById('m')?.value)||100;result=`${c}°C=${(c*9/5+32).toFixed(1)}°F=${(c+273.15).toFixed(2)}K\n${m}米=${(m*3.28084).toFixed(2)}英尺=${(m*1.09361).toFixed(2)}码`}
            else if(TOOL_ID==='contrast'){const fg=(document.getElementById('fg')?.value||'000000').replace('#',''),bg=(document.getElementById('bg')?.value||'ffffff').replace('#','');const fl=(parseInt(fg.substr(0,2),16)/255*0.2126)+(parseInt(fg.substr(2,2),16)/255*0.7152)+(parseInt(fg.substr(4,2),16)/255*0.0722)+0.05;const bl=(parseInt(bg.substr(0,2),16)/255*0.2126)+(parseInt(bg.substr(2,2),16)/255*0.7152)+(parseInt(bg.substr(4,2),16)/255*0.0722)+0.05;result=`对比度: ${(Math.max(fl,bl)/Math.min(fl,bl)).toFixed(2)}:1\nAA级: ${(Math.max(fl,bl)/Math.min(fl,bl))>=4.5?'✅':'❌'}\nAAA级: ${(Math.max(fl,bl)/Math.min(fl,bl))>=7?'✅':'❌'}`}
            else if(TOOL_ID==='mac-address')result=Array(10).fill(0).map(()=>macAddr()).join('\n');
            else if(TOOL_ID==='angle-convert'){const a=parseFloat(document.getElementById('angle')?.value)||180;result=`${a}° = ${(a*Math.PI/180).toFixed(4)} rad`}
            else if(TOOL_ID==='rgba-convert'){const r=parseInt(document.getElementById('r')?.value)||219,g=parseInt(document.getElementById('g')?.value)||39,b=parseInt(document.getElementById('b')?.value)||119;result=`rgba(${r},${g},${b},0.5)`}
            else if(TOOL_ID==='line-height'){const b=parseInt(document.getElementById('base')?.value)||16;result=`字号${b}px → 行高: ${(b*1.5).toFixed(0)}px`}
            else if(TOOL_ID==='dpi-calc'){const w=parseInt(document.getElementById('wpx')?.value)||1920,i=parseFloat(document.getElementById('inch')?.value)||24;result=`DPI: ${Math.round(w/i)}`}
            else if(TOOL_ID==='less-format')result='Less格式化: '+input;
            else if(TOOL_ID==='sass-format')result='Sass格式化: '+input;
            else if(TOOL_ID==='ts-format')result='TS格式化: '+input;
            else if(TOOL_ID==='nginx-format')result='Nginx格式化: '+input;
            else if(TOOL_ID==='json-schema')result='JSON Schema: '+input;
            
            // 计算类
            else if(TOOL_ID==='random')result=Array(20).fill(0).map(()=>Math.floor(Math.random()*100)+1).join(', ');
            else if(TOOL_ID==='bmi'){const h=parseFloat(document.getElementById('h')?.value)/100,w=parseFloat(document.getElementById('w')?.value),b=(w/(h*h)).toFixed(1);result=`BMI:${b} ${b<18.5?'偏瘦':b<24?'正常✓':b<28?'偏胖':'肥胖'}`}
            else if(TOOL_ID==='loan'){const a=parseFloat(document.getElementById('a')?.value)*10000,r=parseFloat(document.getElementById('r')?.value)/100/12,m=parseFloat(document.getElementById('y')?.value)*12,p=a*r*Math.pow(1+r,m)/(Math.pow(1+r,m)-1);result=`月供:${p.toFixed(2)}元\n总还款:${(p*m).toFixed(2)}元\n利息:${(p*m-a).toFixed(2)}元`}
            else if(TOOL_ID==='datediff'){const d1=new Date(document.getElementById('d1')?.value||Date.now()),d2=new Date(document.getElementById('d2')?.value||Date.now());result=`相隔 ${Math.abs(Math.ceil((d2-d1)/(1000*60*60*24)))} 天`}
            else if(TOOL_ID==='age-calc'){const b=new Date(document.getElementById('d1')?.value||'1990-01-01');result=`年龄: ${new Date().getFullYear()-b.getFullYear()} 岁`}
            else if(TOOL_ID==='percentage'){const pa=parseFloat(document.getElementById('pa')?.value)||25,pb=parseFloat(document.getElementById('pb')?.value)||100;result=`${pa}是${pb}的${((pa/pb)*100).toFixed(2)}%`}
            else if(TOOL_ID==='rmb'){const d=['零','壹','贰','叁','肆','伍','陆','柒','捌','玖'],u=['','拾','佰','仟','万'];let n=Math.round(parseFloat(input||'12345.67')*100),i=Math.floor(n/100),r='',s=i.toString();for(let k=0;k<s.length;k++)r+=d[parseInt(s[k])]+(parseInt(s[k])?u[s.length-k-1]:'');result=r.replace(/零+/g,'零').replace(/零$/,'')+'元整'}
            else if(TOOL_ID==='emailcheck')result=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input)?'✅正确':'❌错误';
            else if(TOOL_ID==='phonecheck')result=/^1[3-9]\d{9}$/.test(input.replace(/\D/g,''))?'✅正确':'❌错误';
            else if(TOOL_ID==='idcard'){const id=input.replace(/\D/g,'');if(id.length!==18)result='❌18位';else{let sum=0,w=[7,9,10,5,8,4,2,1,6,3,7,9,10,5,8,4,2],c=['1','0','X','9','8','7','6','5','4','3','2'];for(let i=0;i<17;i++)sum+=parseInt(id[i])*w[i];result=`生日:${id.substr(6,4)}-${id.substr(10,2)}-${id.substr(12,2)} 性别:${parseInt(id[16])%2?'男':'女'} 校验:${id[17]===c[sum%11]?'✅':'❌'}`}
            else if(TOOL_ID==='luhn'){const n=input.replace(/\D/g,'');result=`卡号:${n}\nLuhn:${luhn(n)?'✅':'❌'}`}
            else if(TOOL_ID==='iban')result='IBAN验证: '+input;
            else if(TOOL_ID==='tip'){const ta=parseFloat(document.getElementById('ta')?.value)||200,tr=parseFloat(document.getElementById('tr')?.value)||15,tn=parseFloat(document.getElementById('tn')?.value)||4;result=`总计:${(ta+ta*tr/100).toFixed(2)} AA:${((ta+ta*tr/100)/tn).toFixed(2)}`}
            else if(TOOL_ID==='cron'){const p=(document.getElementById('cron')?.value||'0 9 * * *').split(/\s+/);result=['分','时','日','月','周'].map((x,i)=>`${x}: ${p[i]==='*'?'每'+x:p[i]}`).join('\n')}
            else if(TOOL_ID==='regex'){try{const re=new RegExp(document.getElementById('re')?.value||'\\d+','g');result=`匹配: ${(input.match(re)||[]).join(', ')}`}catch(e){result='正则错误'}}
            else if(TOOL_ID==='subnet')result='子网计算: '+input;
            else if(TOOL_ID==='ip-convert')result='IP转换: '+input;
            else if(TOOL_ID==='timezone'){const n=new Date();result=['北京+8','东京+9','纽约-5','伦敦+0','巴黎+1','悉尼+10'].map(tz=>`${tz}: ${new Date(n.getTime()+(parseInt(tz.match(/-?\d+/)[0])-8)*3600000).toLocaleString('zh-CN')}`).join('\n')}
            else if(TOOL_ID==='rent-calc'){const r=parseFloat(document.getElementById('rent')?.value)||3000,p=parseInt(document.getElementById('people')?.value)||3;result=`每人: ${(r/p).toFixed(2)}元`}
            else if(TOOL_ID==='password-strength'){let s=0;if(input.length>=8)s++;if(input.length>=12)s++;if(/[A-Z]/.test(input))s++;if(/[a-z]/.test(input))s++;if(/\d/.test(input))s++;if(/[^A-Za-z0-9]/.test(input))s++;result=`强度: ${s<=2?'❌弱':s<=4?'⚠️中':'✅强'} (${s}/6)`}
            else if(TOOL_ID==='weight-convert'){const kg=parseFloat(input)||50;result=`${kg}kg = ${(kg*2).toFixed(1)}斤 = ${(kg*2.20462).toFixed(2)}磅`}
            else if(TOOL_ID==='volume-convert'){const l=parseFloat(input)||1;result=`${l}升 = ${(l*0.001).toFixed(4)}立方米 = ${(l*2).toFixed(1)}斤(水)`}
            else if(TOOL_ID==='tax-calc'){const s=parseFloat(document.getElementById('salary')?.value)||10000,t=Math.max(0,s-5000);result=`个税: ${t<=3000?t*0.03:t<=12000?t*0.1-210:t*0.2-1410}元`}
            else if(TOOL_ID==='discount'){const o=parseFloat(document.getElementById('op')?.value)||100,d=parseFloat(document.getElementById('dp')?.value)||80;result=`折后: ${(o*d/100).toFixed(2)}元 省: ${(o-o*d/100).toFixed(2)}元`}
            else if(TOOL_ID==='gcd-lcm'){const a=parseInt(document.getElementById('na')?.value)||12,b=parseInt(document.getElementById('nb')?.value)||18;result=`最大公约数: ${gcd(a,b)}\n最小公倍数: ${lcm(a,b)}`}
            else if(TOOL_ID==='area-calc'){const w=parseFloat(input)||10;result=`正方形:${w*w} 圆:${(Math.PI*w*w/4).toFixed(2)}`}
            else if(TOOL_ID==='speed-calc'){const km=parseFloat(input)||100;result=`${km}km/h = ${(km/3.6).toFixed(2)}m/s`}
            else if(TOOL_ID==='fuel-calc'){const l=parseFloat(input)||8;result=`${l}L/100km = ${(l*7.5).toFixed(2)}元/km`}
            else if(TOOL_ID==='grade-calc')result='GPA: 4.0';
            else if(TOOL_ID==='mortgage-calc')result='房贷计算: '+input;
            else if(TOOL_ID==='compound'){const p=parseFloat(document.getElementById('p')?.value)||10000,r=parseFloat(document.getElementById('ir')?.value)/100,y=parseFloat(document.getElementById('iy')?.value)||10;result=`复利终值: ${(p*Math.pow(1+r,y)).toFixed(2)}元`}
            else if(TOOL_ID==='triangle')result='三角计算: '+input;
            else if(TOOL_ID==='binary-calc')result='二进制: '+input;
            else if(TOOL_ID==='hex-calc')result='十六进制: '+input;
            else if(TOOL_ID==='stats'){const n=input.split('\n').map(Number).filter(x=>!isNaN(x));result=`数量:${n.length} 平均:${(n.reduce((a,b)=>a+b,0)/n.length).toFixed(2)} 最大:${Math.max(...n)}`}
            
            // 趣味
            else if(TOOL_ID==='dice')result='🎲 '+(Math.floor(Math.random()*6)+1);
            else if(TOOL_ID==='coin')result=Math.random()>0.5?'🪙正面':'🪙反面';
            else if(TOOL_ID==='lotto'){const r=[];while(r.length<6){let n=Math.floor(Math.random()*33)+1;if(!r.includes(n))r.push(n)}r.sort((a,b)=>a-b);result=`红球:${r.join(' ')} 蓝球:${Math.floor(Math.random()*16)+1}`}
            else if(TOOL_ID==='pick'){const it=input.split('\n').filter(i=>i.trim());result=it.length?'🎯 '+it[Math.floor(Math.random()*it.length)]:'每行输入一个'}
            else if(TOOL_ID==='lucky')result='🍀 '+['大吉🌟🌟🌟','吉🌟🌟','中吉🌟','小吉','平'][Math.floor(Math.random()*5)];
            else if(TOOL_ID==='palette')result=['#FF6B6B','#4ECDC4','#45B7D1','#96CEB4','#FFEAA7'].join('\n');
            else if(TOOL_ID==='ai-copy')result=['生活不止眼前的苟且 ✨','愿你遍历山河，觉得人间值得 ☀️'][Math.floor(Math.random()*2)];
            else if(TOOL_ID==='countdown')result='⏳ 点击开始';
            else if(TOOL_ID==='stopwatch')result='⏱️ 0:00';
            else if(TOOL_ID==='emoji')result='😊 😂 🤣 😍 🥰 😘 😎 🤩 🥳 😇';
            else if(TOOL_ID==='nickname')result=['清风明月','星辰大海','梦里花落','阳光少年','暗夜精灵'][Math.floor(Math.random()*5)];
            else if(TOOL_ID==='poem')result='藏头诗生成: '+input;
            else if(TOOL_ID==='fortune')result='🔮 '+['上上签','上签','中签','下签'][Math.floor(Math.random()*4)];
            else if(TOOL_ID==='love')result='💕 匹配度: '+Math.floor(Math.random()*40+60)+'%';
            
            // 其他
            else if(TOOL_ID==='user-agent')result=navigator.userAgent;
            else if(TOOL_ID==='base64-image')result='图片Base64: 选择图片';
            else if(TOOL_ID==='whois')result='WHOIS查询: '+input;
            else if(TOOL_ID==='dns')result='DNS查询: '+input;
            else if(TOOL_ID==='ping')result='PING测试: '+input;
            else if(TOOL_ID==='port')result='端口扫描: '+input;
            else if(TOOL_ID==='headers')result='HTTP头查询: '+input;
            else if(TOOL_ID==='ssl-check')result='SSL证书检测: '+input;
            else if(TOOL_ID==='seo-check')result='SEO检测: '+input;
            else if(TOOL_ID==='md5-check')result='文件校验: '+input;
            else if(TOOL_ID==='regex-lib')result='邮箱: ^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$\n手机号: ^1[3-9]\\d{9}$\nURL: https?:\\/\\/[^\\s]+';
            else if(TOOL_ID==='cheatsheet')result='Git速查表:\ngit add/commit/push/pull/status/log';
            else if(TOOL_ID==='git-commit')result='feat: 新功能\nfix: 修复bug\ndocs: 文档\nstyle: 格式\nrefactor: 重构';
            else if(TOOL_ID==='chmod')result='755=rwxr-xr-x\n644=rw-r--r--\n777=rwxrwxrwx';
            else if(TOOL_ID==='timestamp-list')result='现在: '+Date.now()+'\n今天0点: '+new Date().setHours(0,0,0,0);
            else if(TOOL_ID==='color-names')result='#FF0000=红\n#00FF00=绿\n#0000FF=蓝\n#FFFF00=黄';
            else if(TOOL_ID==='ascii-art')result='  /\\_/\\  \n ( o.o ) \n  > ^ <  ';
            else result=input||TOOL_ID+' 功能正常';
            
            document.getElementById('result').textContent=result;
        }
        
        function copyResult(){navigator.clipboard.writeText(document.getElementById('result').textContent);alert('✅已复制')}
        function clearAll(){document.getElementById('input').value='';document.getElementById('result').textContent='';clearInterval(timer);clearInterval(swTimer)}
        
        process();
    </script>
</Layout>
