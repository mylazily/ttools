const { id } = Astro.params;
const tool = toolMap[id] || { name: '工具', icon: '🛠️', desc: '在线工具' };
---

<Layout title={`${tool.name} - 在线工具`} description={tool.desc}>
    <div class="mb-6">
        <a href="/" class="text-pink-600 hover:underline">← 返回首页</a>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border">
        <h1 class="text-3xl font-bold mb-2 text-gray-800">{tool.icon} {tool.name}</h1>
        <p class="text-gray-600 mb-6">{tool.desc}</p>

        <div class="space-y-4">
            <textarea id="input" rows="5" placeholder="输入内容..." class="w-full p-4 border rounded-lg font-mono"></textarea>
            
            <div class="flex gap-3 flex-wrap">
                <button onclick="process()" class="btn-primary px-6 py-3 font-medium">处理</button>
                <button onclick="clearAll()" class="btn-secondary px-6 py-3 font-medium">清空</button>
                <button onclick="copyResult()" class="btn-secondary px-6 py-3 font-medium">复制结果</button>
            </div>

            <div id="result" class="p-4 bg-gray-50 rounded-lg font-mono min-h-24 hidden"></div>
        </div>
    </div>

    <script>
        function process() {
            const input = (document.getElementById('input') as HTMLTextAreaElement).value;
            const result = document.getElementById('result')!;
            result.textContent = input || '请输入内容';
            result.classList.remove('hidden');
        }
        function clearAll() {
            (document.getElementById('input') as HTMLTextAreaElement).value = '';
            document.getElementById('result')!.classList.add('hidden');
        }
        function copyResult() {
            const text = document.getElementById('result')!.textContent || '';
            navigator.clipboard.writeText(text);
            alert('已复制！');
        }
    </script>
</Layout>
