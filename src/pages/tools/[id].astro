---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
    const tools = ['word-count', 'text-dedup', 'case-convert', 'base64', 'md5', 'json-format', 'timestamp', 'bmi', 'password', 'uuid'];
    return tools.map(id => ({ params: { id } }));
}

const { id } = Astro.params;

const toolNames: Record<string, any> = {
    'word-count': { name: '字数统计', icon: '📏' },
    'text-dedup': { name: '文本去重', icon: '📋' },
    'case-convert': { name: '大小写转换', icon: '🔤' },
    'base64': { name: 'Base64编码', icon: '🔐' },
    'md5': { name: 'MD5加密', icon: '🔍' },
    'json-format': { name: 'JSON格式化', icon: '📝' },
    'timestamp': { name: '时间戳转换', icon: '⏰' },
    'bmi': { name: 'BMI计算器', icon: '⚖️' },
    'password': { name: '密码生成器', icon: '🔐' },
    'uuid': { name: 'UUID生成', icon: '🆔' },
};

const tool = toolNames[id] || { name: '工具', icon: '🛠️' };
---

<Layout title={`${tool.name} - 在线工具箱`} description={tool.name}>
    <div class="card">
        <div class="card-title">
            <div class="card-icon">{tool.icon}</div>
            <h1 class="card-h1">{tool.name}</h1>
        </div>
        
        <textarea id="input" rows="8" placeholder="在此输入内容..."></textarea>
        
        <div class="btn-row">
            <button class="btn-primary" onclick="process()">转换</button>
            <button class="btn-secondary" onclick="copy()">复制</button>
        </div>
        
        <div id="result" class="result-box">结果将显示在这里</div>
    </div>
    
    <script is:inline>
        function process() {
            const v = document.getElementById('input').value;
            document.getElementById('result').textContent = v || '请输入内容';
        }
        function copy() {
            navigator.clipboard.writeText(document.getElementById('result').textContent);
        }
    </script>
</Layout>
