const { id, name, icon } = Astro.props;
---

<Layout title={`${name} - 在线工具箱`} description="">
    <div id="tool-meta" data-tool-id={id} style="display:none;"></div>
    
    <div class="mb-6">
        <a href="/" class="text-pink-600 hover:underline text-sm">← 返回首页</a>
    </div>

    <div class="text-center mb-8">
        <div class="text-5xl mb-4">{icon}</div>
        <h1 class="text-3xl font-bold text-gray-800 mb-2">{name}</h1>
    </div>

    <div class="card">
        <div class="mb-4">
            <textarea id="input" rows="8" placeholder="在此输入内容..." class="w-full"></textarea>
        </div>
        
        <div id="extra-inputs"></div>
        
        <div class="flex flex-wrap gap-3 mb-4">
            <button onclick="process()" class="btn-primary">处理</button>
            <button onclick="copyResult()" class="btn-secondary">复制</button>
            <button onclick="clearAll()" class="btn-secondary">清空</button>
        </div>
        
        <div class="mb-4">
            <label class="block text-gray-700 font-medium mb-2">结果：</label>
            <div id="result" class="result-box"></div>
        </div>
    </div>

    <script is:inline>
        const TOOL_ID = document.getElementById('tool-meta').dataset.toolId;
        
        function crc16(s) {
            let crc = 0xFFFF;
            for(let i=0;i<s.length;i++) {
                crc ^= s.charCodeAt(i);
                for(let j=0;j<8;j++) crc = (crc & 1) ? (crc >> 1) ^ 0xA001 : crc >> 1;
            }
            return crc & 0xFFFF;
        }
        
        function crc32(s) { let c=0^(-1); for(let i=0;i<s.length;i++)c=(c>>>8)^((c^s.charCodeAt(i))&0xFF); return (c^(-1))>>>0; }
        
        function luhn(n) {
            const d=n.replace(/\D/g,'').split('').reverse(); let s=0;
            for(let i=0;i<d.length;i++){let x=parseInt(d[i]);if(i%2===1){x*=2;if(x>9)x-=9}s+=x}
            return s%10===0;
        }
        
        function atbash(s) {
            return s.replace(/[a-zA-Z]/g, c => {
                const b = c <= 'Z' ? 65 : 97;
                return String.fromCharCode(b + 25 - (c.charCodeAt(0) - b));
            });
        }
        
        function rgbToHsl(r,g,b) {
            r/=255;g/=255;b/=255;const max=Math.max(r,g,b),min=Math.min(r,g,b);
            let h,s,l=(max+min)/2;
            if(max===min)h=s=0;else{const d=max-min;s=l>0.5?d/(2-max-min):d/(max+min);
            switch(max){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;case b:h=(r-g)/d+4;break;}h/=6;}
            return [Math.round(h*360),Math.round(s*100),Math.round(l*100)];
        }
        
        function rgbToHsv(r,g,b) {
            r/=255;g/=255;b/=255;const max=Math.max(r,g,b),min=Math.min(r,g,b),d=max-min;
            let h=0,s=max===0?0:d/max,v=max;
            if(max!==min){switch(max){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;case b:h=(r-g)/d+4;break;}h/=6;}
            return [Math.round(h*360),Math.round(s*100),Math.round(v*100)];
        }
        
        function ulid() {
            const e='0123456789ABCDEFGHJKMNPQRSTVWXYZ';
            const t=Date.now();let r='';for(let i=0;i<16;i++)r+=e[Math.floor(Math.random()*32)];
            let s='';for(let i=0;i<10;i++){s=e[t%32]+s;const n=Math.floor(t/32);if(n===t&&i===9)break;t=n}
            return s+r;
        }
        
        function cuid() {
            const h=()=>Math.floor(Math.random()*36).toString(36);
            return 'c'+Date.now().toString(36)+h()+h()+h()+h()+h();
        }
        
        function ksuid() {
            const t=Math.floor(Date.now()/1000)-14e8;
            const e='0123456789ABCDEFGHIJKLMNOPQRSTUV';
            let r='';for(let i=0;i<27;i++)r+=e[Math.floor(Math.random()*32)];
            return t.toString(32).toUpperCase().padStart(9,'0')+r;
        }
        
