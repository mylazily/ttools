---

<Layout title="70+免费在线工具集合" description="70+免费实用在线工具，文本处理、编码转换、计算设计、趣味工具，全部免费无需注册">
    <div style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 2.25rem; font-weight: bold; color: #1f2937; margin-bottom: 1rem;">🛠️ 70+ 免费在线工具</h1>
        <p style="color: #4b5563; font-size: 1.125rem;">文本处理 · 编码转换 · 计算设计 · 趣味工具 · 全部免费</p>
    </div>

    <div class="grid-container">
        {tools.map(tool => (
            <a href={`/tools/${tool.id}`} class="card">
                <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">{tool.icon}</div>
                <h3 style="font-size: 1.125rem; font-weight: bold; margin-bottom: 0.25rem; color: #1f2937;">{tool.name}</h3>
                <p style="color: #6b7280; font-size: 0.875rem;">{tool.desc}</p>
            </a>
        ))}
    </div>
</Layout>
