---
<Layout title="在线工具箱 - 200个免费在线工具" description="200个免费在线工具，无需安装，即开即用">
    <div class="text-center mb-10">
        <h1 class="text-4xl font-bold text-gray-800 mb-4">🛠️ 在线工具箱</h1>
        <p class="text-gray-600 text-lg">200个免费在线工具，无需安装，即开即用</p>
    </div>
    
    {(['文本','编码','转换','计算','趣味','其他'] as const).map(cat => (
        <div class="mb-10">
            <h2 class="text-xl font-bold text-gray-700 mb-4 pb-2 border-b border-gray-200">{cat}工具</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                {tools.filter(t => t.cat === cat).map(tool => (
                    <a href={`/tools/${tool.id}`} class="tool-card">
                        <div class="text-2xl mb-2">{tool.icon}</div>
                        <div class="text-sm font-medium text-gray-700">{tool.name}</div>
                    </a>
                ))}
            </div>
        </div>
    ))}
</Layout>
