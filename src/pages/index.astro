---
import Layout from '../layouts/Layout.astro';

const tools = [
    { id: 'word-count', name: '字数统计', icon: '📏', cat: '文本' },
    { id: 'text-dedup', name: '文本去重', icon: '📋', cat: '文本' },
    { id: 'case-convert', name: '大小写', icon: '🔤', cat: '文本' },
    { id: 'html-escape', name: 'HTML转义', icon: '📝', cat: '文本' },
    { id: 'trim', name: '空格清理', icon: '🧹', cat: '文本' },
    { id: 'base64', name: 'Base64', icon: '🔐', cat: '编码' },
    { id: 'md5', name: 'MD5', icon: '🔍', cat: '编码' },
    { id: 'uuid', name: 'UUID', icon: '🆔', cat: '编码' },
    { id: 'password', name: '密码生成', icon: '🔐', cat: '编码' },
    { id: 'json-format', name: 'JSON格式化', icon: '📝', cat: '转换' },
    { id: 'timestamp', name: '时间戳', icon: '⏰', cat: '转换' },
    { id: 'bmi', name: 'BMI计算', icon: '⚖️', cat: '计算' },
    { id: 'loan', name: '贷款计算', icon: '💰', cat: '计算' },
    { id: 'idcard', name: '身份证', icon: '🪪', cat: '计算' },
    { id: 'dice', name: '掷骰子', icon: '🎲', cat: '趣味' },
    { id: 'qrcode', name: '二维码', icon: '📱', cat: '其他' },
];

const cats = ['文本', '编码', '转换', '计算', '趣味', '其他'];
---

<Layout title="🛠️ 在线工具箱" description="免费在线工具">
    <div class="hero">
        <div class="hero-icon">🛠️</div>
        <h1 class="hero-title">在线工具箱</h1>
        <p class="hero-desc">免费在线工具 · 无需安装 · 即开即用</p>
    </div>
    
    <input type="text" id="search" placeholder="🔍 搜索工具..." class="search" oninput="filterTools()">
    
    <div class="stats">
        <div class="stat"><div class="stat-num">{tools.length}</div><div class="stat-label">总计</div></div>
        {cats.map(cat => (
            <div class="stat"><div class="stat-num">{tools.filter(t => t.cat === cat).length}</div><div class="stat-label">{cat}</div></div>
        ))}
    </div>
    
    {cats.map(cat => (
        <div id={cat}>
            <h2 class="section-title">{cat}工具</h2>
            <div class="tools-grid">
                {tools.filter(t => t.cat === cat).map(tool => (
                    <a href={`/tools/${tool.id}`} class="tool-card">
                        <div class="tool-icon">{tool.icon}</div>
                        <div class="tool-name">{tool.name}</div>
                    </a>
                ))}
            </div>
        </div>
    ))}
    
    <script is:inline>
        function filterTools() {
            const q = document.getElementById('search').value.toLowerCase();
            document.querySelectorAll('.tool-card').forEach(card => {
                card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
</Layout>
