---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
import SearchBox from '../components/SearchBox.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools, categories } from '../data/tools';

export const prerender = true;

const siteName = '在线工具箱';
const pageTitle = `${siteName} - 200+免费在线工具`;
const pageDesc = '免费在线工具箱，提供文本处理、编码加密、JSON格式化、Base64、MD5、UUID生成等200+实用工具，无需安装，即开即用。';
const keywords = '在线工具,免费工具,文本处理,编码加密,JSON格式化,Base64,MD5,UUID,密码生成,时间戳转换,BMI计算';
const canonical = 'https://ziyuanzu.com/';

// 按分类分组工具
const toolsByCategory = categories.map(cat => ({
  ...cat,
  tools: tools.filter(t => t.category === cat.id),
}));

---

<Layout
  title={siteName}
  description={pageDesc}
  keywords={keywords}
  canonical={canonical}
>
  <!-- 搜索框 -->
  <div class="mb-4">
    <SearchBox />
  </div>

  <!-- 分类工具列表 -->
  {toolsByCategory.map(cat => (
    cat.tools.length > 0 && (
      <section id={cat.id} class="mb-4" data-category-section data-category={cat.id}>
        <h2 class="text-base font-semibold text-gray-800 mb-3 flex items-center gap-2">
          <span class="w-1 h-4 bg-pink-500 rounded-full"></span>
          <span>{cat.icon}</span>
          <span>{cat.name.zh}</span>
          <span class="text-xs text-gray-400 font-normal">({cat.tools.length})</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
          {cat.tools.map(tool => (
            <ToolCard
              id={tool.id}
              icon={tool.icon}
              name={tool.name.zh}
              desc={tool.desc.zh}
              category={cat.id}
              keywords={tool.keywords}
            />
          ))}
        </div>
      </section>
    )
  ))}

  <!-- 无搜索结果提示 -->
  <div id="no-results" class="hidden text-center py-20">
    <div class="text-4xl mb-4">🔍</div>
    <p class="text-gray-500 mb-2">未找到匹配的工具</p>
    <p class="text-xs text-gray-400">试试其他关键词</p>
  </div>

  <BottomNav slot="bottom-nav" />
</Layout>

<script is:inline>
  (function() {
    // 监听搜索无结果的情况
    var input = document.getElementById('search-input');
    var noResults = document.getElementById('no-results');
    
    if (input && noResults) {
      input.addEventListener('input', function() {
        var k = input.value.trim();
        if (!k) {
          noResults.classList.add('hidden');
          return;
        }
        
        setTimeout(function() {
          var visibleCards = document.querySelectorAll('[data-tool-card]:not([style*="display: none"])');
          if (visibleCards.length === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        }, 50);
      });
    }
  })();
</script>
