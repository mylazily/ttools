const cats = ['文本', '编码', '转换', '计算', '趣味', '其他'];
const counts = cats.map(c => tools.filter(t => t.cat === c).length);
---

<Layout title="🛠️ 在线工具箱" description="免费在线工具">
    <div class="text-center mb-10">
        <div class="text-6xl mb-4">🛠️</div>
        <h1 class="text-3xl font-bold mb-3 bg-gradient-to-r from-pink-600 to-rose-500 bg-clip-text text-transparent">
            在线工具箱
        </h1>
        <p class="text-gray-600 mb-6">免费在线工具 · 无需安装 · 即开即用</p>
        <div class="max-w-lg mx-auto">
            <input type="text" id="search" placeholder="🔍 搜索工具..." class="search-box w-full" oninput="filterTools()">
        </div>
    </div>
    
    <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-7 gap-3 mb-8">
        <div class="stat-card">
            <div class="text-2xl font-bold text-pink-600">{tools.length}</div>
            <div class="text-xs text-gray-500">总计</div>
        </div>
        {cats.map((cat, i) => (
            <div class="stat-card">
                <div class="text-xl font-bold text-gray-700">{counts[i]}</div>
                <div class="text-xs text-gray-500">{cat}</div>
            </div>
        ))}
    </div>
    
    <div class="mb-8">
        <h2 class="text-lg font-bold text-gray-700 mb-4">🔥 热门工具</h2>
        <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
            {hotTools.map(tool => (
                <a href={`/tools/${tool.id}`} class="tool-card">
                    <div class="text-xl mb-1">{tool.icon}</div>
                    <div class="text-xs font-medium text-gray-700">{tool.name}</div>
                </a>
            ))}
        </div>
    </div>
    
    {cats.map(cat => (
        <div id={cat} class="mb-8">
            <h2 class="text-lg font-bold text-gray-700 mb-4 pb-2 border-b border-pink-200">
                {cat}工具
            </h2>
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3 tool-grid" data-cat={cat}>
                {tools.filter(t => t.cat === cat).map(tool => (
                    <a href={`/tools/${tool.id}`} class="tool-card" data-name={tool.name.toLowerCase()}>
                        <div class="text-xl mb-1">{tool.icon}</div>
                        <div class="text-xs font-medium text-gray-700">{tool.name}</div>
                    </a>
                ))}
            </div>
        </div>
    ))}
    
    <script is:inline>
        function filterTools() {
            const q = document.getElementById('search').value.toLowerCase().trim();
            document.querySelectorAll('.tool-grid > a').forEach(a => {
                a.style.display = a.dataset.name.includes(q) ? '' : 'none';
            });
        }
    </script>
</Layout>
