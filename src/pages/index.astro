---
import Layout from '../layouts/Layout.astro';
---

<Layout title="🛠️ 在线工具箱" description="免费在线工具">
    <div style="text-align:center;margin-bottom:30px;">
        <div style="font-size:50px;margin-bottom:10px;">🛠️</div>
        <h1 style="font-size:24px;font-weight:bold;color:#ec4899;margin-bottom:5px;">在线工具箱</h1>
        <p style="color:#666;font-size:14px;">免费在线工具 · 无需安装 · 即开即用</p>
    </div>
    
    <!-- 用HTML Table布局！绝对不会错位！ -->
    <table width="100%" cellpadding="6" cellspacing="0" style="margin-bottom:30px;">
        <tr>
            <td><a href="/tools/word-count" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">📏</div>
                <div style="font-size:12px;color:#333;">字数统计</div>
            </a></td>
            <td><a href="/tools/text-dedup" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">📋</div>
                <div style="font-size:12px;color:#333;">文本去重</div>
            </a></td>
            <td><a href="/tools/base64" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">🔐</div>
                <div style="font-size:12px;color:#333;">Base64</div>
            </a></td>
        </tr>
        <tr>
            <td><a href="/tools/md5" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">🔍</div>
                <div style="font-size:12px;color:#333;">MD5</div>
            </a></td>
            <td><a href="/tools/json-format" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">📝</div>
                <div style="font-size:12px;color:#333;">JSON</div>
            </a></td>
            <td><a href="/tools/timestamp" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">⏰</div>
                <div style="font-size:12px;color:#333;">时间戳</div>
            </a></td>
        </tr>
    </table>
    
    <h2 style="font-size:16px;font-weight:bold;color:#333;margin:30px 0 15px;padding-bottom:8px;border-bottom:2px solid #fce7f3;">常用工具</h2>
    
    <table width="100%" cellpadding="6" cellspacing="0">
        <tr>
            <td><a href="/tools/password" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">🔐</div>
                <div style="font-size:12px;color:#333;">密码生成</div>
            </a></td>
            <td><a href="/tools/uuid" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">🆔</div>
                <div style="font-size:12px;color:#333;">UUID</div>
            </a></td>
            <td><a href="/tools/bmi" style="display:block;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:18px 8px;text-align:center;text-decoration:none;">
                <div style="font-size:24px;margin-bottom:6px;">⚖️</div>
                <div style="font-size:12px;color:#333;">BMI计算</div>
            </a></td>
        </tr>
    </table>
</Layout>
